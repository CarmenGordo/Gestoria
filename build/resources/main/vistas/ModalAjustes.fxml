    <Pane fx:id="paneCreditos" prefHeight="50.0" prefWidth="328.0">
        <Label fx:id="textCreditos" alignment="CENTER" layoutY="17.0" prefHeight="0.0" prefWidth="328.0" text="Creado por: Carmen Gordo" textAlignment="CENTER" />
    </Pane>

