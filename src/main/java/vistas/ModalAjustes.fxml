<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<FlowPane fx:id="modalAjustes" alignment="CENTER" columnHalignment="CENTER" hgap="10" orientation="VERTICAL" prefHeight="334.0" prefWidth="329.0" vgap="10" xmlns="http://javafx.com/javafx/23" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controladores.ControladorModalAjustes">
    <Button fx:id="btnCerrarAjustes" alignment="TOP_RIGHT" onAction="cerrarModalAjustes" text="X" />
    <VBox alignment="CENTER" spacing="10">
        <Button fx:id="btnVerCreditos" onAction="verCreditos" text="Ver Créditos" />
        <Button fx:id="btnSalir" onAction="salir" text="Salir" />
    </VBox>
    
    <Pane fx:id="paneCreditos" visible="false">
        <Label alignment="CENTER" text="Aquí están los créditos" />
    </Pane>

</FlowPane>
